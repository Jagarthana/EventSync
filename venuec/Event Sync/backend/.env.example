PORT=5000

# Local MongoDB (default). If you see ECONNREFUSED, either:
#   - run: docker compose up -d   (in this backend folder), or
#   - install/start MongoDB Community, or
#   - use Atlas and paste your URI below instead.
MONGO_URI=mongodb://127.0.0.1:27017/eventsync

# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/eventsync?retryWrites=true&w=majority

JWT_SECRET=change-this-in-production
